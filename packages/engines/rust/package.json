{
  "name": "@docmd/engine-rust",
  "version": "0.8.4",
  "description": "Rust-accelerated engine for docmd. Downloads pre-built binary at install time.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "files": [
    "dist",
    "scripts",
    "bin"
  ],
  "keywords": [
    "docmd",
    "engine",
    "rust",
    "native",
    "performance",
    "markdown",
    "minimalist",
    "zero-config",
    "site-generator",
    "documentation",
    "docs"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docmd-io/docmd.git"
  },
  "bugs": {
    "url": "https://github.com/docmd-io/docmd/issues"
  },
  "homepage": "https://docmd.io",
  "funding": "https://github.com/sponsors/mgks",
  "license": "MIT"
}