{
  "name": "@docmd/core",
  "version": "0.7.0",
  "description": "The zero-config documentation engine. Markdown to production docs in one command.",
  "type": "module",
  "browser": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "docmd": "dist/bin/docmd.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/bin/docmd.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@docmd/live": "workspace:*",
    "@docmd/parser": "workspace:*",
    "@docmd/plugin-analytics": "workspace:*",
    "@docmd/plugin-installer": "workspace:*",
    "@docmd/plugin-llms": "workspace:*",
    "@docmd/plugin-mermaid": "workspace:*",
    "@docmd/plugin-pwa": "workspace:*",
    "@docmd/plugin-search": "workspace:*",
    "@docmd/plugin-seo": "workspace:*",
    "@docmd/plugin-sitemap": "workspace:*",
    "@docmd/themes": "workspace:*",
    "@docmd/ui": "workspace:*",
    "chalk": "^4.1.2",
    "esbuild": "^0.28.0",
    "ws": "^8.20.0"
  },
  "keywords": [
    "docmd",
    "markdown",
    "minimalist",
    "zero-config",
    "site-generator",
    "static-site-generator",
    "documentation",
    "typescript",
    "javascript",
    "nodejs",
    "browser",
    "website",
    "generator",
    "hosted",
    "cli",
    "ssg",
    "docs"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docmd-io/docmd.git"
  },
  "bugs": {
    "url": "https://github.com/docmd-io/docmd/issues"
  },
  "homepage": "https://docmd.io",
  "funding": "https://github.com/sponsors/mgks",
  "license": "MIT"
}