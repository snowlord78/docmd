{
  "name": "@docmd/plugin-search",
  "version": "0.8.4",
  "description": "Offline full-text search for docmd.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && esbuild src/client.ts --bundle --outfile=dist/docmd-search.js --format=esm --platform=browser --minify"
  },
  "files": [
    "dist",
    "i18n"
  ],
  "dependencies": {
    "minisearch": "^7.2.0"
  },
  "devDependencies": {
    "@docmd/api": "workspace:*",
    "@types/markdown-it": "^14.1.2",
    "esbuild": "^0.28.0",
    "markdown-it": "^14.1.1"
  },
  "keywords": [
    "docmd",
    "plugin",
    "search",
    "minisearch",
    "offline",
    "indexing",
    "keyword-matching",
    "markdown",
    "minimalist",
    "zero-config",
    "site-generator",
    "static-site-generator",
    "docs"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docmd-io/docmd.git"
  },
  "bugs": {
    "url": "https://github.com/docmd-io/docmd/issues"
  },
  "homepage": "https://docmd.io",
  "funding": "https://github.com/sponsors/mgks",
  "license": "MIT"
}