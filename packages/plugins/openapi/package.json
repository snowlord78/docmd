{
  "name": "@docmd/plugin-openapi",
  "version": "0.8.0",
  "description": "OpenAPI documentation generator plugin for docmd.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node build.js"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@docmd/api": "workspace:*"
  },
  "devDependencies": {
    "@docmd/api": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "docmd",
    "plugin",
    "openapi",
    "swagger",
    "rest",
    "api-docs",
    "documentation",
    "markdown",
    "static-site-generator",
    "zero-config",
    "docs"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docmd-io/docmd.git"
  },
  "bugs": {
    "url": "https://github.com/docmd-io/docmd/issues"
  },
  "homepage": "https://docmd.io",
  "funding": "https://github.com/sponsors/mgks",
  "license": "MIT"
}