{
  "name": "@docmd/monorepo",
  "version": "0.5.4",
  "private": true,
  "description": "The minimalist, zero-config documentation generator monorepo.",
  "scripts": {
    "test": "node scripts/failsafe.js",
    "lint": "pnpm -r run lint",
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @docmd/playground dev",
    "stop": "pnpm --filter @docmd/core exec docmd stop",
    "playground:add": "pnpm --filter @docmd/playground exec docmd add",
    "playground:remove": "pnpm --filter @docmd/playground exec docmd remove",
    "release": "pnpm publish -r --access public",
    "clean": "rm -rf node_modules packages/*/node_modules packages/plugins/*/node_modules packages/*/site packages/plugins/*/site packages/*/dist",
    "bump": "node scripts/bump.js"
  },
  "devDependencies": {
    "chalk": "4.1.2",
    "eslint": "^9.39.3",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.32.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "minimatch": ">=10.2.1",
      "ajv": ">=6.14.0"
    }
  },
  "workspaces": [
    "packages/*",
    "packages/plugins/*"
  ],
  "keywords": [
    "docmd",
    "markdown",
    "minimalist",
    "zero-config",
    "site-generator",
    "static-site-generator",
    "documentation",
    "typescript",
    "javascript",
    "nodejs",
    "html",
    "browser",
    "website",
    "generator",
    "parser",
    "hosted",
    "cli",
    "ssg",
    "docs"
  ],
  "author": {
    "name": "Ghazi",
    "url": "https://mgks.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/docmd-io/docmd.git"
  },
  "bugs": {
    "url": "https://github.com/docmd-io/docmd/issues"
  },
  "homepage": "https://docmd.io",
  "funding": "https://github.com/sponsors/mgks",
  "license": "MIT"
}
